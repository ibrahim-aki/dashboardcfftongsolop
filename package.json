{
  "name": "clone-file-finder",
  "version": "1.0.0",
  "description": "Ultra-performance duplicate file finder for PC",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "duplicate",
    "finder",
    "clone",
    "cleaner",
    "electron"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.4.1"
  },
  "build": {
    "appId": "com.antigravity.clonefinder",
    "win": {
      "target": "portable"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase": "^12.12.0"
  }
}
